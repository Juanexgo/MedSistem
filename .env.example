# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://mediflow:mediflow@localhost:5433/mediflow?schema=public"

# ─── JWT (IMPORTANT: Change secrets in production!) ─────────
JWT_ACCESS_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-secure-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
CSRF_SECRET="change-me-to-another-secure-random-string-at-least-32-chars"

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
API_PREFIX="/api/v1"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# ─── Rate Limiting ──────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
LOGIN_THROTTLE_TTL=300
LOGIN_THROTTLE_LIMIT=5

# ─── Security ───────────────────────────────────────────────
HELMET_ENABLED=true
CORS_ENABLED=true
BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_SECRET_MIN_LENGTH=32

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL="debug"
LOG_FORMAT="pretty"
